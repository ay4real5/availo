PORT=4000
# Set to "production" on deployed environments. This enforces JWT_SECRET and
# CORS_ORIGIN below; leaving it unset keeps dev conveniences (open CORS).
NODE_ENV=development

# Required to authenticate the scraper/admin endpoints. The backend FAILS CLOSED
# if this is unset, so always set a strong random value in production.
SCRAPER_API_KEY=dev-scraper-key

# REQUIRED in production: strong random secret used to sign user JWTs.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Comma-separated list of allowed browser origins (REQUIRED in production).
# Example: https://app.availo.co.uk,https://availo.co.uk
CORS_ORIGIN=

DEV_STORE_PATH=dev-store.json

# Optional: real Supabase (Postgres) backend. Leave blank to use dev-store.json.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Email notifications via Resend (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=Availo <alerts@availo.co.uk>

# Optional: Slack alerting for quarantine spikes
SLACK_WEBHOOK_URL=
QUARANTINE_ALERT_THRESHOLD=5
DISABLE_SPIKE_DETECTOR=false
