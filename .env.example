# Root environment checklist
# Copy this file to backend/.env and scraper/.env and fill in real values.
# NEVER commit .env files to Git.

# Backend
PORT=4000
SCRAPER_API_KEY=dev-scraper-key

# Optional: real Supabase (Postgres) backend. Leave blank to use dev-store.json.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: Slack alerting for quarantine spikes
SLACK_WEBHOOK_URL=
QUARANTINE_ALERT_THRESHOLD=5
DISABLE_SPIKE_DETECTOR=false

# Scraper
BACKEND_URL=http://localhost:4000
MOCK_URL=http://localhost:8000
CONCURRENCY=2
