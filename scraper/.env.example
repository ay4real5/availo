BACKEND_URL=http://localhost:4000
MOCK_URL=http://localhost:8000
SCRAPER_API_KEY=dev-scraper-key

# Booking journey target. 'mock' drives the local test harness (scraper/mock_site).
# 'dvsa' (live service) is intentionally NOT implemented and will raise — enabling
# it requires a deliberate decision and Terms-of-Service/legal review.
TARGET=mock

# How many centres to scrape concurrently in run_workers.js
CONCURRENCY=5

# Supervisor tuning (scraper/supervisor.js)
SUPERVISOR_MAX_RETRIES=5
SUPERVISOR_BASE_DELAY_MS=1000
SUPERVISOR_MAX_DELAY_MS=30000
SUPERVISOR_RUN_INTERVAL_MS=60000

# Proxy rotation: comma-separated list of REAL residential proxies. When set,
# requests are routed through these (http(s):// or socks5://). Leave empty for
# local dev (the worker advertises a fake source IP via header instead).
# e.g. http://user:pass@gw.residential-provider.com:8000,socks5://user:pass@host:1080
PROXY_LIST=

# CAPTCHA solver simulator delay (seconds)
CAPTCHA_SOLVER_DELAY=2

# Real CAPTCHA solving provider. When set, challenges are routed to 2captcha
# instead of the local simulator. Leave empty for local dev.
TWOCAPTCHA_API_KEY=
TWOCAPTCHA_TIMEOUT=120

# TLS fingerprint impersonation (curl_cffi). 'chrome' tracks a recent Chrome
# build; pin a version like 'chrome124' if needed. Falls back to httpx if
# curl_cffi is not installed.
TLS_IMPERSONATE=chrome

# Real-browser discovery (Playwright). Set true to drive the HTML journey in a
# genuine headless Chromium (run `playwright install chromium` first). Falls
# back to curl_cffi automatically if unavailable.
USE_PLAYWRIGHT=false

# Detection feedback loop: how many fresh identities/proxies to try when blocked.
MAX_IDENTITY_ATTEMPTS=3

# Proxy intelligence
PROXY_MAX_CONSECUTIVE_FAILURES=3   # quarantine a proxy after this many failures
PROXY_QUARANTINE_SECONDS=900       # how long a quarantined proxy stays benched
PROXY_HEALTHCHECK_URL=https://api.ipify.org?format=json

# Backend resilience (circuit breaker)
BACKEND_CB_THRESHOLD=5   # open the breaker after this many consecutive failures
BACKEND_CB_COOLDOWN=30   # seconds the breaker stays open

# Worker behaviour tuning
QUEUE_TIMEOUT_SECONDS=300   # abort if queue hasn't cleared after this many seconds
SEARCH_DAYS_MIN=7            # minimum days ahead to search for slots
SEARCH_DAYS_MAX=42           # maximum days ahead to search for slots
AUTO_BOOK=false              # set to true to attempt automatic booking after finding slots
